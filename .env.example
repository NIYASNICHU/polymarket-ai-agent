# polymarket-veil-agent/.env.example
# ── Polymarket ─────────────────────────────────────────────────────────────────
POLYMARKET_API_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_PRIVATE_KEY=0x...           # wallet private key for signing orders
POLYMARKET_PROXY_ADDRESS=0x...         # your CTF Exchange proxy address

# ── Veil Gateway ───────────────────────────────────────────────────────────────
VEIL_GATEWAY_URL=http://localhost:8080
VEIL_MODEL_ID=polymarket_mlp_v1

# ── Agent behaviour ────────────────────────────────────────────────────────────
MIN_CONFIDENCE=0.65         # skip trades below this threshold (0.5–1.0)
MAX_BET_SIZE_USDC=5.0       # max USDC per trade
POLL_INTERVAL_SECS=30       # how often to scan markets
MIN_VOLUME_24H=5000         # skip markets below this 24h volume (USDC)
WEIGHTS_PATH=weights/polymarket_mlp_v1.bin
PAPER_TRADING=true          # set to false only when ready for real bets

# ── Trainer ────────────────────────────────────────────────────────────────────
MAX_MARKETS=500             # resolved markets to fetch for training
EPOCHS=200
LEARNING_RATE=0.001
WEIGHTS_OUT=weights/polymarket_mlp_v1.bin

# ── Dashboard ──────────────────────────────────────────────────────────────────
# RECORDS_PATH=records/trades_20240405_120000.jsonl   # auto-detected if unset
